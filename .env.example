# --- Database (Supabase Postgres, transaction pooler) ---
# Supabase → Project "Rebuilt" → Settings → Database → Connection string →
# "Transaction pooler" (port 6543). Reset the DB password there if needed.
# Our tables live in the `umkreis` schema (pinned via search_path in lib/db.js).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- Poster-scan / crawl extraction ---
# Primary: Google Gemini Flash-Lite (cheapest per image, strong German OCR).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Fallback: Claude (Haiku) for hard posters / when GEMINI_API_KEY is unset.
# Without either key, scan falls back to the local `claude` CLI if installed.
ANTHROPIC_API_KEY=

# Optional model overrides
# GEMINI_MODEL=gemini-2.5-flash-lite
# EXTRACT_MODEL=claude-haiku-4-5

# Absolute base URL for sitemap.xml + share links (set on Vercel to the live domain)
# NEXT_PUBLIC_BASE_URL=https://okolo.events

# --- Analytics (PostHog, EU-hosted) ---
# Create a dedicated project at https://eu.posthog.com → Project settings → copy
# the "Project API Key" (starts with phc_). Analytics is OFF until this is set,
# so local/preview runs don't send data.
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Rate limiting ---
# Salt for hashing IPs in the durable rate limiter (any long random string).
# RATELIMIT_SALT=

# --- Admin ---
# Password for the admin surfaces (the Thursday desk at /admin/thursday).
# You type it once; the server sets an httpOnly signed cookie good for 30 days.
# Min 8 chars — but use a long random one (`openssl rand -base64 24`), since it
# also keys the session signature: changing it logs every device out.
# Unset = the admin is CLOSED (no password, no way in), never open.
# ADMIN_PASSWORD=
#
# Separate secret, ONLY for the one-click "remove entry" link in submission
# notification emails (min 16 chars, e.g. `openssl rand -hex 24`) — a mail
# client can't present a login form, so that one link carries a token.
# ADMIN_TOKEN=

# --- Email (routed in lib/mail.js: Resend first, then SMTP) ---
# ALL outbound mail — the double-opt-in confirmation, signup pings, and the
# weekly newsletter — goes through one of these. With NEITHER set, the newsletter
# signup returns a 503 rather than pretending it sent a confirmation.
#
# Option 1 — Resend (recommended). An HTTP API, so it works on serverless with no
# outbound SMTP socket, and it handles SPF/DKIM/DMARC so mail lands in the inbox.
# Verify the okolo.events domain in the Resend dashboard first, then:
# RESEND_API_KEY=re_...
# MAIL_FROM=Okolo <hello@okolo.events>   # must be on the verified domain
#
# Option 2 — SMTP (Migadu or any host). Create an SMTP password for a mailbox in
# the Migadu admin (Mailboxes → password); SMTP_USER is that full address.
# SMTP_USER=hello@okolo.events
# SMTP_PASS=
# SMTP_HOST=smtp.migadu.com   # optional (default)
# SMTP_PORT=465               # optional (default; 465 = SSL)
#
# NOTIFY_TO — where signup pings + "Send test to me" land (defaults to SMTP_USER).
# NOTIFY_TO=
