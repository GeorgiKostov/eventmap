# --- Database (Supabase Postgres, transaction pooler) ---
# Supabase → Project "Rebuilt" → Settings → Database → Connection string →
# "Transaction pooler" (port 6543). Reset the DB password there if needed.
# Our tables live in the `umkreis` schema (pinned via search_path in lib/db.js).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- Poster-scan / crawl extraction ---
# Primary: Google Gemini Flash-Lite (cheapest per image, strong German OCR).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Fallback: Claude (Haiku) for hard posters / when GEMINI_API_KEY is unset.
# Without either key, scan falls back to the local `claude` CLI if installed.
ANTHROPIC_API_KEY=

# Optional model overrides
# GEMINI_MODEL=gemini-2.5-flash-lite
# EXTRACT_MODEL=claude-haiku-4-5

# Absolute base URL for sitemap.xml + share links (set on Vercel to the live domain)
# NEXT_PUBLIC_BASE_URL=https://okolo.events

# --- Analytics (PostHog, EU-hosted) ---
# Create a dedicated project at https://eu.posthog.com → Project settings → copy
# the "Project API Key" (starts with phc_). Analytics is OFF until this is set,
# so local/preview runs don't send data.
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Rate limiting ---
# Salt for hashing IPs in the durable rate limiter (any long random string).
# RATELIMIT_SALT=

# --- Email notifications (Migadu SMTP) ---
# Pings you when someone subscribes to the newsletter. No-op unless both
# SMTP_USER and SMTP_PASS are set. Create an SMTP password for a mailbox in the
# Migadu admin (Mailboxes → password). SMTP_USER is that full mailbox address.
# SMTP_USER=hello@okolo.events
# SMTP_PASS=
# NOTIFY_TO=            # where signup pings go (defaults to SMTP_USER)
# SMTP_HOST=smtp.migadu.com   # optional (default)
# SMTP_PORT=465               # optional (default; 465 = SSL)
