# Claude API key — needed for the poster-scan feature and `npm run crawl`.
# Get one at https://platform.claude.com. Without it, the scan feature falls back
# to the locally installed `claude` CLI (Claude Code) if available.
ANTHROPIC_API_KEY=

# Extraction model (default: claude-haiku-4-5; use claude-sonnet-5 for harder pages)
# EXTRACT_MODEL=claude-haiku-4-5
